void Turntable_Control_thread(void *p)/* 转台控制任务 */
{
	uint32_t status_r=0,DATA;
	while(1)
	{
		DATA=0XAB010100;
		PRO_FPGA_CTRL_mWriteReg(XPAR_PRO_FPGA_CTRL_0_S00_AXI_BASEADDR, PRO_FPGA_CTRL_S00_AXI_SLV_REG1_OFFSET,DATA);
		status_r++;
		PRO_FPGA_CTRL_mWriteReg(XPAR_PRO_FPGA_CTRL_0_S00_AXI_BASEADDR, PRO_FPGA_CTRL_S00_AXI_SLV_REG0_OFFSET,status_r);
		vTaskDelay(1000);
	}
}

void PL_AXI_PS_thread(void *p)/* PL端与PS端通信任务 */
{
	int16_t am2302_temp;
	uint32_t status_r,work_cnt_now,work_cnt_last,am2302_humi;
	uint8_t T_H_array[4]={0};
	while(1)
	{
    	vTaskDelay(1000);  // 遵守传感器采样间隔
    	status_r=PRO_FPGA_CTRL_mReadReg(XPAR_PRO_FPGA_CTRL_0_S00_AXI_BASEADDR, PRO_FPGA_CTRL_S00_AXI_SLV_REG16_OFFSET);
    	if(status_r>0)
    	{
    		work_cnt_now=status_r;
    		//-- status
    		//-- 0  : 正常
    		//-- 1  : 没有检测到低电平
    		//-- 2  : 响应低电平不在75us--85us范围内
    		//-- 3  : 响应高电平不在75us--85us范围内
    		//-- 4  : 信号低电平不在48us--55us范围内
    		//-- 5  : 信号高电平不在22us--30us或68us--75us范围内
    		//-- 6  : sum check error
    		if(work_cnt_now!=work_cnt_last)
    		{
    			am2302_temp=PRO_FPGA_CTRL_mReadReg(XPAR_PRO_FPGA_CTRL_0_S00_AXI_BASEADDR, PRO_FPGA_CTRL_S00_AXI_SLV_REG17_OFFSET)&0xffff;
    			am2302_humi=PRO_FPGA_CTRL_mReadReg(XPAR_PRO_FPGA_CTRL_0_S00_AXI_BASEADDR, PRO_FPGA_CTRL_S00_AXI_SLV_REG18_OFFSET)&0xffff;
    			T_H_array[0]=am2302_temp&0xff;
    			T_H_array[1]=(am2302_temp>>8)&0xff;
    			T_H_array[2]=am2302_humi&0xff;
    			T_H_array[3]=(am2302_humi>>8)&0xff;
    			xQueueSend(Temp_Humi_display_Queue,T_H_array,0);
    			xQueueSend(Temp_Humi_send_Queue,T_H_array,0);
    			memset(&T_H_array[0] ,0, 4);
        		xil_printf("work_cnt_now %d\t\n",work_cnt_now);
        		xil_printf("status_r %d\t\n",status_r);
    			xil_printf("temperature %d\t\n",am2302_temp);
    			xil_printf("humidity %d\t\n",am2302_humi);
        		work_cnt_last=work_cnt_now;
    		}
    	}
	}
}

