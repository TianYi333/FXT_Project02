void PS_AXI_TO_PL_thread(void *p)/* PS¶Л·ўЛНөҪPL¶ЛИООс*/
{
	uint32_t work_cnt=0,DATA=0;
	while(1)
	{
		DATA=0XAB020100;
		PRO_FPGA_CTRL_mWriteReg(XPAR_PRO_FPGA_CTRL_0_S00_AXI_BASEADDR, PRO_FPGA_CTRL_S00_AXI_SLV_REG1_OFFSET,DATA);
		work_cnt++;
		PRO_FPGA_CTRL_mWriteReg(XPAR_PRO_FPGA_CTRL_0_S00_AXI_BASEADDR, PRO_FPGA_CTRL_S00_AXI_SLV_REG0_OFFSET,work_cnt);
		vTaskDelay(1000);
	}
}

void PL_AXI_TO_PS_thread(void *p)/* PL¶Л·ўЛНөҪPS¶ЛИООс */
{
	int16_t am2302_temp;
	uint32_t work_cnt_now,work_cnt_last,am2302_humi;
	while(1)
	{
    	vTaskDelay(1000);  // ЧсКШҙ«ёРЖчІЙСщјдёф
    	work_cnt_now=PRO_FPGA_CTRL_mReadReg(XPAR_PRO_FPGA_CTRL_0_S00_AXI_BASEADDR, PRO_FPGA_CTRL_S00_AXI_SLV_REG16_OFFSET);
    	if(work_cnt_now>0)
    	{
    		if(work_cnt_now!=work_cnt_last)
    		{
    			am2302_temp=PRO_FPGA_CTRL_mReadReg(XPAR_PRO_FPGA_CTRL_0_S00_AXI_BASEADDR, PRO_FPGA_CTRL_S00_AXI_SLV_REG17_OFFSET)&0xffff;
    			am2302_humi=PRO_FPGA_CTRL_mReadReg(XPAR_PRO_FPGA_CTRL_0_S00_AXI_BASEADDR, PRO_FPGA_CTRL_S00_AXI_SLV_REG18_OFFSET)&0xffff;
        		xil_printf("work_cnt_now %d\t\n",work_cnt_now);
    			xil_printf("temperature %d\t\n",am2302_temp);
    			xil_printf("humidity %d\t\n",am2302_humi);
        		work_cnt_last=work_cnt_now;
    		}
    	}
	}
