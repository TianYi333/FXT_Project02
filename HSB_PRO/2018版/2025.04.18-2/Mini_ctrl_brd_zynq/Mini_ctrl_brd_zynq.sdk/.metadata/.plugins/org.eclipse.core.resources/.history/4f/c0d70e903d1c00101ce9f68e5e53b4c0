void LED_thread(void *p)/* LED任务 */
{
	//EMIO配置为输出
	XGpioPs_SetDirectionPin(&gpiops_inst, LED_GREEN,1);
    XGpioPs_SetDirectionPin(&gpiops_inst, LED_RED,1);
    //使能EMIO输出
    XGpioPs_SetOutputEnablePin(&gpiops_inst, LED_GREEN,1);
    XGpioPs_SetOutputEnablePin(&gpiops_inst, LED_RED,1);
	while(1)
	{
		XGpioPs_WritePin(&gpiops_inst, LED_GREEN, 0);//EMIO的第0位输出0
		XGpioPs_WritePin(&gpiops_inst, LED_RED, 1);//EMIO的第1位输出0
		printf("LED 1!\n");
		vTaskDelay(10000);
		XGpioPs_WritePin(&gpiops_inst, LED_GREEN, 1);//EMIO的第0位输出0
		XGpioPs_WritePin(&gpiops_inst, LED_RED, 0);//EMIO的第1位输出0
		printf("LED 2!\n");
		vTaskDelay(10000);
	}
}

