void Temperature_And_Humidity_Reading_thread(void *p)/* ОВКЄ¶И¶БИЎИООс */
{
	uint8_t retries;
	uint8_t raw[5];
	SensorData_t sensor_data;
	while(1)
	{
    	vTaskDelay(3000);  // ЧсКШґ«ёРЖчІЙСщјдёф
        xSemaphoreTake(xBusMutex, portMAX_DELAY);  // »сИЎЧЬПЯ·ГОКИЁ

        retries = DHT_RETRIES;
        while (retries--) {
            sensor_data.status = ReadData(raw);
            if (sensor_data.status == 0) break;
            vTaskDelay(50);  // ЦШКФјдёф
        }

        if (sensor_data.status == 0) {
            // КэѕЭЧЄ»»
            sensor_data.humidity = (raw[0] * 256.0 + raw[1]) / 10.0;
            int16_t temp = (raw[2] & 0x7F) * 256 + raw[3];
            sensor_data.temp = temp / 10.0;
            if (raw[2] & 0x80) sensor_data.temp *= -1;
        }
        xSemaphoreGive(xBusMutex);                  // КН·ЕЧЬПЯ


		if (sensor_data.status == 0) {
			xil_printf("[Success] Humidity: %.1f%%, Temp: %.1fC\r\n",
					sensor_data.humidity, sensor_data.temp);
		} else {
		xil_printf("[Error %d] ", sensor_data.status);
		if (sensor_data.status == -1) xil_printf("Timeout\r\n");
		else if (sensor_data.status == -2) xil_printf("Checksum\r\n");
		}
    }
}


